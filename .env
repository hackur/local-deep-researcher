# Local Deep Researcher - Environment Configuration
# Docs: https://github.com/langchain-ai/local-deep-researcher

# Search API: duckduckgo (free, no key needed), tavily, perplexity, searxng
SEARCH_API=duckduckgo

# API Keys (optional - only needed if using tavily/perplexity)
# TAVILY_API_KEY=tvly-xxxxx
# PERPLEXITY_API_KEY=pplx-xxxxx

# === LLM Provider ===
# Options: ollama, lmstudio
LLM_PROVIDER=lmstudio

# LMStudio API endpoint (default, should be running)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Default model (can be overridden per run via the UI or env)
# See available model IDs below in comments
LOCAL_LLM=crow-9b-opus-4.6-distill-heretic_qwen3.5

# === Available LMStudio Model IDs (as reported by LMStudio server) ===
# crow-9b-opus-4.6-distill-heretic_qwen3.5        ← Crow 9B Opus 4.6 Distill (GGUF)
# openai/gpt-oss-20b                               ← GPT-OSS 20B (MXFP4)
# zai-org/glm-4.6v-flash                           ← GLM-4.6v Flash
# nvidia/nemotron-3-nano                           ← Nemotron 3 Nano
# zai-org/glm-4.7-flash                            ← GLM-4.7 Flash
# qwen/qwen3.5-9b                                  ← Qwen3.5 9B Q8_0

# === Research Settings ===
MAX_WEB_RESEARCH_LOOPS=3
FETCH_FULL_PAGE=True

# Use tool calling instead of JSON mode (required for most LMStudio models)
# LMStudio models often only support json_schema or text, not json_object
USE_TOOL_CALLING=True
